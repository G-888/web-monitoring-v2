APP_NAME=WebMonitor
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://monitor.example.com
APP_PORT=8000

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=web_monitor
DB_USERNAME=webmonitor
DB_PASSWORD=replace-with-strong-password
DB_ROOT_PASSWORD=replace-with-strong-root-password

SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=alerts@example.com
MAIL_FROM_NAME="${APP_NAME}"

AGENT_API_KEY=
AGENT_GLOBAL_API_KEY_ENABLED=true
AGENT_AUTO_REGISTER_SERVERS=true
AGENT_METRICS_MAX_BYTES=262144
AGENT_IIS_LOG_SUMMARY_MAX_BYTES=1048576
AGENT_NETWORK_RESULTS_MAX_BYTES=262144
AGENT_METRICS_RATE_LIMIT_PER_MINUTE=12
AGENT_IIS_LOG_SUMMARY_RATE_LIMIT_PER_MINUTE=20
AGENT_NETWORK_RESULTS_RATE_LIMIT_PER_MINUTE=60
AGENT_NETWORK_CHECKS_ENABLED=false
AGENT_IIS_LOGS_ENABLED=false

REPORT_STORAGE_DISK=local
LOG_INGESTION_ENABLED=false
IIS_LOG_MONITORING_ENABLED=false
NETWORK_MONITORING_ENABLED=false
SECURITY_BLOCK_PRIVATE_SCAN_IPS=true
SECURITY_ALLOWED_SCAN_DOMAINS=
SECURITY_ALLOWED_SCAN_CIDRS=

SEO_SEARCH_ENABLED=false
SEO_SEARCH_PROVIDERS=commoncrawl,wayback,urlscan,crtsh,google,brave
SEO_SEARCH_RESULT_LIMIT=10
BING_SEARCH_KEY=
GOOGLE_SEARCH_KEY=
GOOGLE_SEARCH_CX=
BRAVE_SEARCH_KEY=

MONITORING_RETENTION_METRICS_DAYS=90
MONITORING_RETENTION_CHECK_RESULTS_DAYS=180
MONITORING_RETENTION_IIS_SUMMARIES_DAYS=90
MONITORING_RETENTION_IIS_SUSPICIOUS_DAYS=180
MONITORING_RETENTION_NETWORK_RESULTS_DAYS=180
MONITORING_RETENTION_DATABASE_CHECKS_DAYS=180
MONITORING_RETENTION_REPORT_FILES_DAYS=365
